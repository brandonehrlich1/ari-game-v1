{
  "name": "ari-game-v1",
  "version": "0.1.0",
  "description": "Mobile AR webapp game: back-camera, characters in spheres placed every 10-20 ft, synced from Google Drive, with an admin panel.",
  "type": "module",
  "scripts": {
    "start": "node server/server.js",
    "dev": "node --watch server/server.js",
    "seed": "node scripts/seed.js",
    "sync": "node scripts/sync-drive.js",
    "build:cards": "node scripts/build-cards-manifest.mjs",
    "check:cards": "node scripts/build-cards-manifest.mjs --check",
    "build:bible": "node tools/build-bible.mjs",
    "gen:art": "node tools/gen-art.mjs",
    "compose:cards": "node tools/compose-cards.mjs"
  },
  "dependencies": {
    "express": "^4.19.2",
    "googleapis": "^144.0.0",
    "sharp": "^0.34.5"
  },
  "engines": {
    "node": ">=20"
  }
}
