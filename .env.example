# Copy to .env (kept out of git) and fill in.

# Port the server listens on
PORT=3000

# Optional: require this token in the admin panel for saving config / syncing.
# Leave blank for open access during local dev.
ADMIN_TOKEN=

# --- Google Drive sync ---
# The shared Drive folder that holds 151-200 character images.
DRIVE_FOLDER_ID=

# Path to a Google service-account key JSON file (or paste the raw JSON).
# The service account needs read access to the folder above (share it with
# the service account's email).
GOOGLE_SERVICE_ACCOUNT_JSON=./service-account.json
